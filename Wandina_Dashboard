<!DOCTYPE html>
<html>
<head>
  <title>Wandina Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body{
      font-family: Arial;
      padding: 20px;
      background:#f5f7fb;
    }

    .card{
      background:#fff;
      padding:16px;
      border-radius:14px;
      margin-bottom:12px;
      box-shadow:0 6px 18px rgba(0,0,0,0.08);
    }

    h1{
      margin-bottom:20px;
    }

    h2{
      margin:0 0 10px;
    }
  </style>
</head>

<body>

<h1>Wandina Strategy Dashboard</h1>

<div class="card">
  <h2>Current Position</h2>
  <p>Use your main app values to guide decisions.</p>
</div>

<div class="card">
  <h2>Rent Guarantee</h2>
  <p>$700/week for 2 years</p>
</div>

<div class="card">
  <h2>CGT Rule</h2>
  <p>Do NOT sell before 12 months (contract date rule)</p>
</div>

<div class="card">
  <h2>Decision Triggers</h2>
  <ul>
    <li>&lt;$720k → HOLD</li>
    <li>$720k–$780k → WATCH</li>
    <li>&gt;$780k → CONSIDER SELL</li>
  </ul>
</div>

</body>
</html>
